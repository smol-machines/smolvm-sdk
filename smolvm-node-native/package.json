{
  "name": "@smolvm/node-native",
  "version": "0.1.0",
  "description": "Native Node.js SDK for smolvm — embed microVMs directly in your Node.js process (no daemon required)",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "native"
  ],
  "napi": {
    "binaryName": "smolvm-napi",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build:native": "cd ../../smolvm/crates/smolvm-napi && napi build --platform --release --output-dir ../../../smolvm-sdk/smolvm-node-native/native",
    "build:ts": "tsup src/index.ts --format cjs,esm --dts",
    "build": "npm run build:native && npm run build:ts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "smolvm",
    "microvm",
    "sandbox",
    "virtualization",
    "container",
    "native",
    "napi"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 18.0.0"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@types/node": "^20.0.0"
  }
}
