{
  "name": "smolvm",
  "version": "0.1.0",
  "description": "TypeScript SDK for smolvm microVM machine management",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-generator-cli generate -i ../openapi/openapi.json -g typescript-fetch -o ./src/generated --additional-properties=supportsES6=true,typescriptThreePlus=true,withInterfaces=true",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --reporter=verbose",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run generate && npm run build"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.15.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "@types/node": "^20.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "smolvm",
    "machine",
    "microvm",
    "container",
    "isolation"
  ],
  "license": "Apache-2.0"
}
